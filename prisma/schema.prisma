// Medflex ProjektHub – Datenmodell
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ProjectStatus {
  LAUFEND
  PAUSIERT
  ABGESCHLOSSEN
}

enum TicketStatus {
  NEU
  IN_PROGRESS
  DONE
}

enum TicketPriority {
  HOCH
  MITTEL
  NIEDRIG
}

/// Spiegelt einen Supabase-Auth-User (auth.users.id) für App-spezifische Profildaten.
model User {
  id          String       @id
  email       String       @unique
  name        String
  role        String       @default("Manager")
  projects        Project[]
  tickets         Ticket[]         @relation("TicketCreator")
  assignedTickets Ticket[]         @relation("TicketAssignee")
  statReports              StatReport[]
  comments                 ProjectComment[]
  ticketComments           TicketComment[]
  assignedSupportEntries   ChangeRequest[]  @relation("SupportAssignee")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Project {
  id            String          @id @default(cuid())
  name          String
  status        ProjectStatus   @default(LAUFEND)
  /// Hex-Farbe aus der Projekt-Palette (Badges, Gantt, Kalender)
  color         String
  ownerId       String
  owner         User            @relation(fields: [ownerId], references: [id])
  /// Startdatum, sobald "Projekt berechnen" ausgeführt wurde
  startDate     DateTime?
  /// = letztes Schedule-Step-Enddatum minus 1 Monat
  deadline      DateTime?
  calculated    Boolean         @default(false)
  steps         ScheduleStep[]
  checklist     ChecklistItem[]
  testingEntries TestingEntry[]
  comments      ProjectComment[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([ownerId])
}

/// Berechneter Schritt aus dem 22-Schritte-Ablauf (Stabsübergabe → Monitoring-Besprechung)
model ScheduleStep {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  /// Reihenfolge gemäss scheduleSteps-Definition (0-21)
  order     Int
  startDate DateTime
  endDate   DateTime

  @@index([projectId])
  @@index([startDate, endDate])
}

/// Ticket im Ticketboard (Spalten: Neu, In Progress, Done)
model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String         @default("")
  status      TicketStatus   @default(NEU)
  priority    TicketPriority @default(MITTEL)
  creatorId   String
  creator     User           @relation("TicketCreator", fields: [creatorId], references: [id])
  assigneeId  String?
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  ticketComments TicketComment[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([creatorId])
  @@index([assigneeId])
  @@index([status])
}

/// Kommentar innerhalb eines Tickets
model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@index([ticketId])
}

/// Punkt der 34-teiligen Checkliste je Projekt
model ChecklistItem {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     String
  checked   Boolean  @default(false)
  /// Reihenfolge in der Checkliste (bestimmte Punkte lösen via PHASE_TRIGGER_ORDERS Timeline-Phasen aus)
  order     Int

  @@index([projectId])
}

/// Statistik-Builder: ein Kunden-Report mit Kennzahlen + Tabellen-Daten für die Dashboard-Charts
model StatReport {
  id      String @id @default(cuid())
  /// Kundenname
  title   String
  /// Datum bzw. Zeitraum, z. B. "Mai 2026" oder "01.05.–31.05.2026"
  period  String @default("")

  callCount         Int    @default(0)
  writtenCount      Int    @default(0)
  forwardCount      Int    @default(0)
  /// z. B. "4:32 min"
  avgCallDuration   String @default("")
  /// z. B. "10:00–11:00 Uhr"
  popularCallTime   String @default("")

  /// [{ month, minutes }]
  callDurationByMonth Json @default("[]")
  /// [{ status: "vollständig" | "unvollständig" | "abgebrochen", count }]
  statusBreakdown     Json @default("[]")
  /// [{ label, percent }]
  topTags             Json @default("[]")
  /// [{ weekday, count }] Mo–So
  requestsByWeekday   Json @default("[]")
  /// [{ month, count }]
  requestsByMonth     Json @default("[]")
  /// [{ channel, count }] Telefon/Chat/Kontaktseite
  requestsByChannel   Json @default("[]")
  /// [{ hour, count }] 0–23
  requestsByHour      Json @default("[]")
  /// [{ label, count }]
  requestsByDay       Json @default("[]")

  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

/// Kommentar in der Projekt-Kommentarspalte (Projektinformationen & Details)
model ProjectComment {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  message   String
  createdAt DateTime @default(now())

  @@index([projectId])
}

/// Übergeordnete Support-Anfrage: Kontaktdaten des Kunden (Wrapper für mehrere Einträge)
model SupportRequest {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kontaktperson String          @default("")
  praxisKunde   String          @default("") @map("praxis_kunde")
  email         String          @default("")
  archived      Boolean         @default(false)
  createdAt     DateTime        @default(now()) @map("created_at")
  entries       ChangeRequest[]

  @@map("support_requests")
}

/// Einzelner Eintrag (Sub-Ticket) innerhalb einer Support-Anfrage
model ChangeRequest {
  id                    String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  supportRequestId      String               @map("support_request_id") @db.Uuid
  supportRequest        SupportRequest       @relation(fields: [supportRequestId], references: [id], onDelete: Cascade)
  datum                 DateTime             @db.Date
  kategorie             String               @default("sonstiges")
  prioritaet            String               @default("mittel")
  beschreibungProblem   String               @default("") @map("beschreibung_problem")
  linkAnfrage           String               @default("") @map("link_anfrage")
  fehlerhaftesVerhalten String               @default("") @map("fehlerhaftes_verhalten")
  erwartesVerhalten     String               @default("") @map("erwartes_verhalten")
  status                String               @default("offen")
  assigneeId            String?              @map("assignee_id")
  assignee              User?                @relation("SupportAssignee", fields: [assigneeId], references: [id])
  screenshots           ScreenshotAttachment[]
  archived              Boolean              @default(false)
  createdAt             DateTime             @default(now()) @map("created_at")

  @@index([supportRequestId])
  @@index([assigneeId])
  @@map("change_requests")
}

/// Screenshot-Anhang pro Eintrag (base64-kodiert)
model ScreenshotAttachment {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  changeRequestId String        @map("change_request_id") @db.Uuid
  changeRequest   ChangeRequest @relation(fields: [changeRequestId], references: [id], onDelete: Cascade)
  filename        String
  mimeType        String        @default("image/png") @map("mime_type")
  data            String
  createdAt       DateTime      @default(now()) @map("created_at")

  @@index([changeRequestId])
  @@map("screenshot_attachments")
}

/// Eintrag im Testing-Protokoll eines Projekts
model TestingEntry {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  /// Link zur Anfrage
  link        String   @default("")
  /// Fehlerhaftes Verhalten
  issue       String   @default("")
  comment     String   @default("")
  order       Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([projectId])
}
